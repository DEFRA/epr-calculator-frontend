@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var BackLink = "Dashboard";
}
<div class="govuk-width-container">

    <main class="govuk-main-wrapper govuk-!-padding-top-4" id="main-content" role="main">

        <div class="govuk-grid-row">
            <div class="govuk-grid-column-full">
                <div class="govuk-body account-info">
                    <div>
                        <span class="your-name" id="bannerUserName">Jamie Roberts</span><a class="account-link" href="details" id="signout-link">Sign out</a>
                    </div>
                </div><br>
                <br>

                <!--<h1 class="govuk-heading-xl">You have successfully deleted this file</h1>-->

                <div class="govuk-grid-row">
                    <div class="govuk-grid-column-two-thirds">

                        <div class="govuk-notification-banner govuk-notification-banner--success" role="alert" aria-labelledby="govuk-notification-banner-title" data-module="govuk-notification-banner">
                            <div class="govuk-notification-banner__header">
                                <h2 class="govuk-notification-banner__title" id="govuk-notification-banner-title">
                                    File deleted
                                </h2>
                            </div>
                            <div class="govuk-notification-banner__content">
                                <h3 class="govuk-notification-banner__heading">
                                    Test data check 2
                                </h3>
                                <!-- Need update the below status once the correct information avilavle : Note: Please do not develop the line starting 'Contact....' as the correct contact details are currently unknown. -->
                               @*  <p class="govuk-body">Contact <a class="govuk-notification-banner__link" href="#">example@department.gov.uk</a> if you think there’s a problem.</p> *@
                            </div>
                        </div>
                        <form action="/form-handler" method="post" novalidate="">
                            <input type="hidden" name="answers-checked" value="true">
                            <div class="govuk-button-group">
                                <a href="@Url.Action("Index", "Dashboard")" class="govuk-button" type="submit">Return to the dashboard</a>
                            </div>
                        </form>

                    </div>
                </div>
            </div>
        </div>
    </main>
</div>