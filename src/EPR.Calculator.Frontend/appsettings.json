{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Identity": "Warning",
      "Microsoft.Identity.Web": "Warning",
      "System.Net.Http": "Information"
    }
  },
  "AllowedHosts": "*",
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "Enter Tenant ID",
    "ClientId": "Enter ClientID",
    "CallbackPath": "/signin-oidc",
    "ClientSecret": "Enter Client secret",
    "CallbackUrl": "./Signin-oidc",
    "SignoutCallbackUrl": "./Signout-oidc"
  },
  "DownstreamApi": {
    "BaseUrl": "https://graph.microsoft.com/v1.0/",
    "RelativePath": "me",
    "Scopes": [
      "user.read"
    ]
  },
  "EnableSecurity": "False",
  "ApplicationInsights": {
    "ConnectionString": "Copy connection string from Application Insights Resource Overview"
  },
  "EprCalculatorApiService": {
    "BaseUrl": "http://localhost:5055"
  },
  "CalculationRunSettings": {
    "DownloadResultTimeoutInMilliSeconds": 30000
  },
  "BlobStorage": {
    "ConnectionString": "UseDevelopmentStorage=true"
  },
  "SessionTimeOut": "20",
  "RelativeYearStartingMonth": 4
}